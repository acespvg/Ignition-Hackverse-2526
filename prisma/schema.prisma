generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Registration {
  id                 String   @id @default(uuid())
  teamName           String
  teamSize           Int
  pptLink            String
  videoLink          String
  paymentScreenshot  String
  registrationStatus String   @default("pending")

  // ✅ Leader Relation (1–1)
  leaderId String @unique
  leader   Participant @relation("LeaderRelation", fields: [leaderId], references: [id])

  // ✅ Members Relation (1–many)
  members Participant[] @relation("MemberRelation")

  createdAt DateTime @default(now())
}

model Participant {
  id                   String @id @default(uuid())
  firstName            String
  lastName             String
  email                String
  mobile               String
  gender               String
  instituteName        String
  type                 String
  course               String
  courseSpecialization String
  graduationYear       String
  isAcesMember         Boolean
  receipt              String?

  // ✅ Leader back relation (no FK here)
  registrationLeader Registration? @relation("LeaderRelation")

  // ✅ Member foreign key (important)
  registrationMemberId String?
  registrationMember   Registration? @relation("MemberRelation", fields: [registrationMemberId], references: [id])

  @@index([registrationMemberId]) // 🔥 performance boost
}